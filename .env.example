BOT_TOKEN=your_bot_token_here
BOT_USERNAME=MystVPN_bot

DATABASE_URL=postgresql+asyncpg://user:password@localhost/mystvpn_bot
REDIS_HOST=localhost
REDIS_PORT=6379

YOOKASSA_ACCOUNT_ID=your_account_id
YOOKASSA_SECRET_KEY=your_secret_key

ADMIN_IDS=your_telegram_user_id

WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=your_webhook_secret

# ─── 3x-ui / XRay панель (для выдачи VPN ключей) ────────
XRAY_HOST=key.mysteriovpn.com        # IP или домен VPN сервера (используется в ключе)
XRAY_PORT=54321                      # Порт панели 3x-ui (по умолчанию 54321)
XRAY_USERNAME=admin                  # Логин панели 3x-ui
XRAY_PASSWORD=your_panel_password    # Пароль панели 3x-ui
XRAY_INBOUND_ID=1                    # ID инбаунда в 3x-ui
XRAY_ADDRESS=https://key.mysteriovpn.com:54321  # Полный URL панели (если отличается от XRAY_HOST:XRAY_PORT)

# ─── Прокси (для Telegram в ограниченных регионах) ────
PROXY_HOST=
PROXY_PORT=
# PROXY_LOGIN=login    # Опционально
# PROXY_PASS=password  # Опционально
