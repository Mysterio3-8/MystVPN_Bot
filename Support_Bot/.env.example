# Токен саппорт-бота (отдельный бот, не VPN-бот!)
SUPPORT_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff

# ID группы поддержки в Telegram (отрицательное число для супергруппы)
# Как получить: добавь @userinfobot в группу, он напишет ID
SUPPORT_GROUP_ID=-1001234567890

# ID саппорт-агентов через запятую (могут отвечать на тикеты)
# Необязательно если у всех в группе права отвечать
SUPPORT_ADMIN_IDS=123456789,987654321

# Путь к SQLite БД
DB_PATH=support.db

# Ключ для будущей ИИ-интеграции (Claude / OpenAI)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
