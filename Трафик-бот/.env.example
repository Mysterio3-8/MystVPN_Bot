# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Sponsor channel name (without @)
SPONSOR_CHANNEL=your_sponsor_channel

# Private channel ID (can be obtained via @getmyid_bot)
PRIVATE_CHANNEL_ID=-1001234567890

# Path to welcome photo (relative to bot directory)
WELCOME_PHOTO_PATH=welcome_photo.jpg

# Welcome message text
WELCOME_TEXT=🔒 Хочешь посмотреть на меня?

выполни два условия:
1️⃣ Подпишись на канал.
2️⃣ Нажми «Проверить подписку» здесь, в боте.

# Database path (optional, defaults to bot_data.db)
DATABASE_PATH=bot_data.db

# Invite link expiration time in seconds (optional, defaults to 3600)
INVITE_LINK_EXPIRE_TIME=3600

# Admin IDs (comma-separated, optional)
ADMIN_IDS=

# Max links per user (optional, defaults to 1)
MAX_LINKS_PER_USER=1

# Log level (optional, defaults to INFO)
LOG_LEVEL=INFO